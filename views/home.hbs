<section id="catalog">
    <h1>All Movies</h1>
    <div class="band">
        {{#if (hasMovies movies)}}
            {{#each movies}}
                {{> movieCard}}
            {{/each}}
        {{else}}
            <div class="no-posts">
                <p class="no-offer">There are no posts yet...</p>
            </div>
        {{/if}}
    </div>
</section>
