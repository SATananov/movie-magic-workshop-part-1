<section id="search">
    <h1>Search</h1>
    <form action="/search" method="GET" class="form">
        <input type="text" class="search" name="title" placeholder="Title..." value="{{filter.title}}">
        <input type="text" name="genre" class="genre" placeholder="Genre..." value="{{filter.genre}}">
        <input type="number" name="year" class="year" placeholder="Year..." value="{{filter.year}}">
        <input type="submit" value="search">
    </form>
</section>

<section id="catalog">
    <div class="band">
        {{#if (hasMovies movies)}}
            {{#each movies}}
                {{> movieCard}}
            {{/each}}
        {{else}}
            <div class="no-posts">
                <p class="no-offer">There are no movies matched...</p>
            </div>
        {{/if}}
    </div>
</section>
