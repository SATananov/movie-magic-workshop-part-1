<section id="create-page">
    <div class="createSection">
        <div class="info">
            <h2>"Today, I consider myself the luckiest man on the face of the earth." -The Pride of the Yankees, 1942</h2>
        </div>

        <form action="/create" method="POST" class="createForm">
            <h2>Add Movie</h2>
            <ul class="noBullet">
                <li>
                    <label for="title">Title:</label>
                    <input type="text" class="inputFields" id="title" name="title" value="">
                </li>
                <li>
                    <label for="category">Category:</label>
                    <select id="category" class="inputFields" name="category">
                        <option value="">Select Category</option>
                        <option value="TV Show">TV Show</option>
                        <option value="Animation">Animation</option>
                        <option value="Movie">Movie</option>
                        <option value="Documentary">Documentary</option>
                        <option value="Short Film">Short Film</option>
                    </select>
                </li>
                <li>
                    <label for="genre">Genre:</label>
                    <input type="text" class="inputFields" id="genre" name="genre" value="">
                </li>
                <li>
                    <label for="director">Director:</label>
                    <input type="text" class="inputFields" id="director" name="director" value="">
                </li>
                <li>
                    <label for="year">Year:</label>
                    <input type="number" class="inputFields" id="year" name="year" value="">
                </li>
                <li>
                    <label for="imageURL">Movie Poster:</label>
                    <input type="text" class="inputFields" id="imageURL" name="imageURL" value="">
                </li>
                <li>
                    <label for="rating">Rating:</label>
                    <input type="number" class="inputFields" id="rating" name="rating" min="0" max="5" value="">
                </li>
                <li>
                    <label for="description">Description:</label>
                    <textarea id="description" class="inputFields" name="description"></textarea>
                </li>

                <li id="center-btn">
                    <button id="create-btn" type="submit">Add Movie</button>
                </li>
            </ul>
        </form>
    </div>
</section>
